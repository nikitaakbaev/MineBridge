{
  "name": "minebridge-frp-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + React frontend for MineBridge FRP.",
  "author": {
    "name": "MineBridge FRP Contributors",
    "email": "noreply@minebridge.local"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "backend": "minebridge-frp-api",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3",
    "tailwind-merge": "^2.5.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true
  },
  "build": {
    "appId": "com.minebridge.frp",
    "productName": "MineBridge FRP",
    "asar": true,
    "directories": {
      "output": "dist-installer",
      "buildResources": "resources/icons"
    },
    "files": [
      "electron/**/*",
      "dist-electron/renderer/**/*",
      "minebridge_frp/**/*",
      "pyproject.toml",
      "README.md",
      "!**/__pycache__",
      "!**/*.pyc",
      "!**/*.pyo"
    ],
    "extraResources": [
      {
        "from": "minebridge_frp",
        "to": "backend/minebridge_frp",
        "filter": [
          "**/*.py",
          "**/*.toml",
          "**/*.json",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "pyproject.toml",
        "to": "backend/pyproject.toml"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MineBridge-FRP-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "MineBridge FRP"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "synopsis": "MineBridge FRP launcher",
      "maintainer": "MineBridge FRP Contributors <noreply@minebridge.local>",
      "artifactName": "MineBridge-FRP-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
